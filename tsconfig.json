{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true,
    "outDir": "dist"
  },
  "include": ["apps/*/src/**/*", "packages/*/src/**/*", "tests/**/*", "*.ts"],
  "exclude": ["dist", "node_modules"]
}
